{
  "A2ML SPDX Header": {
    "prefix": "spdx",
    "body": [
      "# SPDX-License-Identifier: ${1:PMPL-1.0-or-later}",
      "# Copyright (c) ${2:2026} ${3:Jonathan D.A. Jewell} (${4:hyperpolymath})",
      ""
    ],
    "description": "Insert SPDX license identifier and copyright header"
  },
  "A2ML Manifest": {
    "prefix": "manifest",
    "body": [
      "# SPDX-License-Identifier: PMPL-1.0-or-later",
      "# AI Manifest for ${1:project-name}",
      "---",
      "format: a2ml",
      "version: ${2:0.1}",
      "---",
      "",
      "canonical-locations:",
      "  scm-files: .machine_readable/",
      "  source: src/",
      "",
      "critical-invariants:",
      "  - ${3:description of invariant}",
      "",
      "lifecycle-hook:",
      "  on-enter:",
      "    - read: 0-AI-MANIFEST.a2ml",
      "    - read: .machine_readable/STATE.scm",
      "  on-exit:",
      "    - update: .machine_readable/STATE.scm",
      ""
    ],
    "description": "Insert a complete A2ML AI manifest template"
  },
  "A2ML Attestation Block": {
    "prefix": "attest",
    "body": [
      "---",
      "attestation:",
      "  attested-by: ${1:agent-name}",
      "  trust-level: ${2|high,medium,low|}",
      "  signature: ${3:signature-hash}",
      "  timestamp: ${4:$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE}",
      "  provenance: ${5:source}",
      "---"
    ],
    "description": "Insert an attestation block"
  },
  "A2ML Gatekeeper Section": {
    "prefix": "gatekeeper",
    "body": [
      "gatekeeper:",
      "  protocol: ${1:0-ai-gatekeeper-protocol}",
      "  enforcement: ${2|hard,soft,advisory|}",
      "  agents:",
      "    - ${3:claude}",
      "    - ${4:gemini}",
      ""
    ],
    "description": "Insert a gatekeeper configuration section"
  },
  "A2ML Section Delimiter": {
    "prefix": "---",
    "body": [
      "---",
      "${1:section-name}:",
      "  ${0}"
    ],
    "description": "Insert a section delimiter with key"
  },
  "A2ML Key-Value Pair": {
    "prefix": "kv",
    "body": [
      "${1:key}: ${2:value}"
    ],
    "description": "Insert a key-value pair"
  },
  "A2ML Checkpoint": {
    "prefix": "checkpoint",
    "body": [
      "checkpoint:",
      "  id: ${1:cp-001}",
      "  status: ${2|pending,complete,blocked|}",
      "  description: ${3:checkpoint description}",
      "  verified: ${4|false,true|}",
      ""
    ],
    "description": "Insert a checkpoint entry"
  }
}
